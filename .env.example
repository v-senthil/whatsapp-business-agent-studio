SESSION_SECRET=change-me-run-openssl-rand-hex-32-and-paste-here
META_API_BASE=https://api.facebook.com
GRAPH_API_BASE=https://graph.facebook.com/v20.0

# Optional, only needed if you configure this app as a Meta webhook callback URL.
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=

# Optional, session lifetime in seconds. Default 28800 (8 hours).
# WABIZ_SESSION_TTL_SECONDS=28800

# Optional, expected host for the same-origin CSRF check on /api/session.
# Set this behind a reverse proxy that rewrites the Host header.
# WABIZ_PUBLIC_HOST=agents.example.com
